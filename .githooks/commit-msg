#!/bin/sh
# Pulse commit-msg meta-lint: rejects AI-attribution lines in commit messages
# (Co-Authored-By / "Generated with" / robot-emoji trailers). Standing repo
# rule: zero attribution in commits.
root="$(git rev-parse --show-toplevel)" || exit 1
if command -v pwsh >/dev/null 2>&1; then
    PS=pwsh
else
    PS=powershell.exe
fi
exec "$PS" -NoProfile -ExecutionPolicy Bypass -File "$root/scripts/meta-lint.ps1" --commit-msg "$1"
